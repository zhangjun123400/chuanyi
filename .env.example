# Backend
HOST=127.0.0.1
PORT=4000

# Frontend
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000

# AI provider routing
# AI_IMAGE_PROVIDER: mock | aliyun | dashscope | segmind | custom | http
# AI_VIDEO_PROVIDER: mock | runway | kling | luma | custom | http
AI_IMAGE_PROVIDER=mock
AI_VIDEO_PROVIDER=mock
AI_PROVIDER_TIMEOUT_MS=300000
AI_PROVIDER_MAX_POLLS=120
AI_PROVIDER_POLL_INTERVAL_MS=3000

# Custom image virtual try-on provider.
# Your service should accept POST JSON and return image_url or output_url.
TRYON_IMAGE_API_URL=
TRYON_IMAGE_API_KEY=

# Segmind image virtual try-on.
# Supported SEGMIND_TRYON_MODEL values: segfit-v1.3 | try-on-diffusion
SEGMIND_API_KEY=
SEGMIND_API_BASE_URL=https://api.segmind.com/v1
SEGMIND_TRYON_MODEL=segfit-v1.3
SEGMIND_MODEL_TYPE=Quality
SEGMIND_IMAGE_FORMAT=jpeg
SEGMIND_IMAGE_QUALITY=90
SEGMIND_CN_STRENGTH=0.8
SEGMIND_CN_END=0.5
SEGMIND_NUM_INFERENCE_STEPS=35
SEGMIND_GUIDANCE_SCALE=2
SEGMIND_SEED=-1
SEGMIND_DEFAULT_MODEL_IMAGE_URL=https://segmind-resources.s3.amazonaws.com/output/d3539958-a892-455e-b00f-aa46e7cfa70b-segfit-v1.3-ip.png

# Alibaba Cloud Model Studio / DashScope AI try-on.
# Requires Beijing region API key and public HTTP/HTTPS image URLs.
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
ALIYUN_TRYON_CREATE_PATH=/api/v1/services/aigc/image2image/image-synthesis
ALIYUN_TRYON_MODEL=aitryon-plus
ALIYUN_TRYON_RESOLUTION=1280
ALIYUN_TRYON_RESTORE_FACE=true
ALIYUN_TRYON_ENABLE_REFINER=true
ALIYUN_REFINER_MODEL=aitryon-refiner
ALIYUN_REFINER_MAX_POLLS=120
ALIYUN_REFINER_POLL_INTERVAL_MS=3000

# Conservative pre-edit before virtual try-on. Uses Agent prompt.
# Recommended for light cleanup/enhancement only; disable if it changes identity or garment details too much.
ALIYUN_PRE_EDIT_ENABLED=true
ALIYUN_PRE_EDIT_MODEL=qwen-image-edit-plus
ALIYUN_PRE_EDIT_MODEL_SIZE=720*1280
ALIYUN_PRE_EDIT_GARMENT_SIZE=1024*1024
ALIYUN_PRE_EDIT_NEGATIVE_PROMPT=low resolution, blurry, distorted face, changed identity, changed garment style, changed color, wrong logo, extra fingers, bad anatomy, watermark
ALIYUN_DEFAULT_PERSON_IMAGE_URL=
ALIYUN_DEFAULT_GARMENT_IMAGE_URL=
ALIYUN_MAX_POLLS=120
ALIYUN_POLL_INTERVAL_MS=3000

# Replicate IDM-VTON alternative try-on provider.
# Model page: https://replicate.com/cuuupid/idm-vton
# Note: the model page marks this model as Non-Commercial use only.
REPLICATE_API_TOKEN=
REPLICATE_API_BASE_URL=https://api.replicate.com/v1
REPLICATE_IDM_VTON_MODEL=cuuupid/idm-vton
REPLICATE_IDM_VTON_VERSION=0513734a452173b8173e907e3a59d19a36266e55b48528559432bd21c7d7e985
REPLICATE_IDM_VTON_STEPS=30
REPLICATE_IDM_VTON_SEED=42
REPLICATE_TIMEOUT_MS=300000
REPLICATE_MAX_POLLS=120
REPLICATE_POLL_INTERVAL_MS=3000

# Pixazo IDM/DM-VTON alternative try-on provider.
# API page: https://www.pixazo.ai/models/idm-vton
PIXAZO_API_KEY=
PIXAZO_IDM_VTON_URL=https://gateway.pixazo.ai/idm-vton-api/v1/r-idm-vton
PIXAZO_IDM_VTON_FALLBACK_URL=https://gateway.appypie.com/idm-vton-api/v1/r-idm-vton
PIXAZO_FASHN_VTON_URL=https://gateway.pixazo.ai/fashn-virtual-try-on/v1/fashn-virtual-try-on-request
PIXAZO_FASHN_MODE=balanced
PIXAZO_FASHN_GARMENT_PHOTO_TYPE=auto
PIXAZO_FASHN_MODERATION_LEVEL=permissive
PIXAZO_FASHN_SEGMENTATION_FREE=true
PIXAZO_FASHN_OUTPUT_FORMAT=png
PIXAZO_TIMEOUT_MS=300000
PIXAZO_MAX_POLLS=120
PIXAZO_POLL_INTERVAL_MS=5000

OPENAI_IMAGE_OPTIMIZER_TIMEOUT_MS=360000

# GPT-Image as primary virtual try-on (skips traditional VTON models).
# Uses the same OPENAI_API_KEY and OPENAI_IMAGE_EDIT_URL as the optimizer.
GPT_IMAGE_TRYON_ENABLED=false
GPT_IMAGE_TRYON_SIZE=1024x1536
GPT_IMAGE_TRYON_QUALITY=high
GPT_IMAGE_TRYON_OUTPUT_FORMAT=png
GPT_IMAGE_TRYON_INPUT_FIDELITY=high
GPT_IMAGE_TRYON_TIMEOUT_MS=360000
GPT_IMAGE_TRYON_MAX_RETRIES=2
GPT_IMAGE_TRYON_RETRY_INTERVAL_MS=3000

# Garment category classifier for better try-on routing.
# It returns shirt / dress / pants and feeds the category into the try-on provider.
GARMENT_CLASSIFIER_ENABLED=true
GARMENT_CLASSIFIER_MODEL=gpt-4o-mini
GARMENT_CLASSIFIER_TIMEOUT_MS=90000

# Post-generation validation: rejects outputs where target garment was not applied.
TRYON_EFFECT_VALIDATOR_ENABLED=true
TRYON_EFFECT_VALIDATOR_MODEL=gpt-4o
TRYON_EFFECT_VALIDATOR_TIMEOUT_MS=90000
PRODUCT_FIDELITY_MAX_RETRIES=3

# Alibaba Cloud OSS. Recommended region: oss-cn-beijing.
ALIYUN_OSS_REGION=oss-cn-beijing
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_READ_EXPIRES_SECONDS=86400
ALIYUN_OSS_PUBLIC_READ=false
# Set ALIYUN_OSS_PUBLIC_READ=true only after the bucket or bucket policy allows public read.
# Keep ALIYUN_OSS_ALLOW_OBJECT_ACL=false when the bucket forbids object-level public ACL.
ALIYUN_OSS_ALLOW_OBJECT_ACL=false
ALIYUN_OSS_OBJECT_ACL=public-read
ALIYUN_OSS_PUBLIC_BASE_URL=https://moteshiyi.oss-cn-beijing.aliyuncs.com

# Public or signed URLs for system model photos. Required for real Aliyun try-on.
SYSTEM_MODEL_EVA_URL=
SYSTEM_MODEL_MIA_URL=
SYSTEM_MODEL_NOAH_URL=

# Runway image-to-video provider.
RUNWAY_API_KEY=
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com
RUNWAY_API_VERSION=2024-11-06
RUNWAY_VIDEO_MODEL=gen4_turbo

# OpenAI-compatible video providers.
# Fill these after opening Kling/Luma or an API aggregator that exposes /v1/video/generations.
# Kling official API with Access Key + Secret Key.
AI_VIDEO_PROVIDER=mock
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
KLING_IMAGE2VIDEO_PATH=/v1/videos/image2video
KLING_STATUS_PATH_TEMPLATE=/v1/videos/image2video/{task_id}
KLING_VIDEO_MODEL=kling-v1-6
KLING_MODE=std
KLING_CFG_SCALE=0.5
KLING_NEGATIVE_PROMPT=distorted body, flickering clothes, warped hands, blurry face
KLING_MAX_POLLS=90
KLING_POLL_INTERVAL_MS=3000

# Kling gateway API mode, if your provider gives a single bearer API key instead
# of official Access Key + Secret Key.
KLING_API_KEY=

LUMA_API_KEY=
LUMA_API_BASE_URL=
LUMA_VIDEO_MODEL=ray

CUSTOM_API_KEY=
CUSTOM_API_BASE_URL=
CUSTOM_VIDEO_MODEL=
